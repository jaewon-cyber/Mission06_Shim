@model Mission06_Shim.Models.Movie

@{ ViewData["Title"] = "Movie Form"; }

<div class="container">
    <h2>Manage Movie</h2>
    <form method="post" asp-action="@(Model.MovieId == 0 ? "EnterMovie" : "Edit")">
        <input type="hidden" asp-for="MovieId" />
        
        <div class="form-group mb-3">
            <label asp-for="CategoryId" class="control-label">Category</label>
            <select asp-for="CategoryId" class="form-control">
                <option value="">Select a Category</option>
                @foreach (var c in ViewBag.Categories)
                {
                    <option value="@c.CategoryId">@c.CategoryName</option>
                }
            </select>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Title">Title</label>
            <input asp-for="Title" class="form-control" />
        </div>
        
        <div class="form-group mb-3">
            <label asp-for="Year">Year</label>
            <input asp-for="Year" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Director">Director</label>
            <input asp-for="Director" class="form-control" />
        </div>
        <div class="form-group mb-3">
            <label asp-for="Rating">Rating</label>
            <select asp-for="Rating" class="form-control">
                <option value="G">G</option>
                <option value="PG">PG</option>
                <option value="PG-13">PG-13</option>
                <option value="R">R</option>
            </select>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Edited">Edited?</label>
            <select asp-for="Edited" class="form-control">
                <option value="false">No</option>
                <option value="true">Yes</option>
            </select>
        </div>
        
        <div class="form-group mb-3">
            <label asp-for="LentTo">Lent To</label>
            <input asp-for="LentTo" class="form-control" />
        </div>
        
        <div class="form-group mb-3">
            <label asp-for="CopiedToPlex">Copied To Plex?</label>
            <select asp-for="CopiedToPlex" class="form-control">
                <option value="false">No</option>
                <option value="true">Yes</option>
            </select>
        </div>
        
        <div class="form-group mb-3">
            <label asp-for="Notes">Notes</label>
            <input asp-for="Notes" class="form-control" maxlength="25" />
        </div>

        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="MovieList" class="btn btn-secondary">Cancel</a>
    </form>
</div>